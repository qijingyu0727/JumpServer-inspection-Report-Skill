# JumpServer 正式巡检报告配置示例
# 推荐复制到 runtime/profiles/prod.env 后按环境修改

## 一、首次接入建议先填的 7 项
JUMPSERVER_URL=https://jumpserver.example.com
JUMPSERVER_USERNAME=admin
JUMPSERVER_PASSWORD=change_me
JumpServer_IP=jumpserver-host
JMS_EXEC_ACCOUNT_NAME=root
JMS_OFFICIAL_SSH_USERNAME=root
JMS_OFFICIAL_SSH_PASSWORD=change_me

# 兼容旧字段：
# JMS_EXEC_ASSET_NAME=jumpserver-host

# 已有 APIKey 时，也可以直接改用：
# JUMPSERVER_KEY_ID=your_access_key_id
# JUMPSERVER_SECRET_ID=your_access_key_secret

## 二、多组织 / 分析默认项
# 兼容旧逻辑：已知默认组织 ID 时可保留
# JUMPSERVER_ORG=00000000-0000-0000-0000-000000000001

# 仅用于展示和默认行为，不参与组织解析
JMS_DEFAULT_ORG_NAME=Default
JMS_DEFAULT_TOP_N=10
JMS_DEFAULT_OUTPUT_FORMAT=html
JMS_AUTO_INSTALL=true
# legacy=正式巡检完整版，modern=控制台摘要版
JMS_REPORT_STYLE=legacy
JMS_LEGACY_PROVIDER=official

# 如环境需要代理或浏览器下载更长超时，可按需打开：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# PLAYWRIGHT_CHROMIUM_DOWNLOAD_HOST=https://storage.googleapis.com/chrome-for-testing-public
# PLAYWRIGHT_DOWNLOAD_HOST=https://playwright.download.prss.microsoft.com
# PLAYWRIGHT_DOWNLOAD_CONNECTION_TIMEOUT=180000

## 三、命令巡检与显式模板场景可选项
# 单机负载巡检默认按资产名称或 IP 匹配；同 IP 命中多台资产时会优先按 Host/Linux、URL 主机名线索、账号存在性与连通状态择优
JMS_EXEC_ENABLED=true
JMS_EXEC_USERNAME=root
JMS_EXEC_COMMANDS=df -Th

# 可选：正式 HTML 报告标题与展示信息
JMS_REPORT_TITLE=JumpServer 堡垒机巡检报告
JMS_REPORT_CUSTOMER=示例环境
JMS_REPORT_COMPANY=杭州飞致云信息科技有限公司
JMS_REPORT_VERSION=v4.x
JMS_REPORT_THEME_COLOR=#4b917d

## 四、official legacy 正式巡检引擎
# legacy 默认走 official，引擎会把 jms_inspect 二进制上传到 JumpServer 服务器后远程执行：
# 1) 系统信息从 JumpServer 节点本机采集
# 2) 数据库/Redis 连接默认读取远端 /opt/jumpserver/config/config.txt
# 3) 产出的 HTML/JSON/Excel 会回收到当前 skill 的 runtime/reports 目录
# 4) 若本地显式配置 DB_* / JMS_DB_*，则本地优先覆盖远端配置

# SSH 端口默认 22
# JMS_OFFICIAL_SSH_PORT=22

# 可选：提权执行，仅支持空值、sudo、su -
# JMS_OFFICIAL_PRIVILEGE_TYPE=
# JMS_OFFICIAL_PRIVILEGE_PASSWORD=

# 可选：远端 JumpServer 配置文件路径
# JMS_OFFICIAL_REMOTE_CONFIG_PATH=/opt/jumpserver/config/config.txt

# 可选：显式覆盖本地 official 二进制路径
# JMS_OFFICIAL_BINARY_PATH=/absolute/path/to/jms_inspect

# 至少配置一个 JumpServer 节点，支持多节点
# 只填了 JumpServer_IP / JMS_EXEC_ACCOUNT_NAME 时，也会默认按同一台 JumpServer 主机尝试巡检
# JMS_SYSTEM_TARGETS=[{"name":"JumpServer 主节点","asset_name":"jumpserver-host","account_name":"root","role":"core"}]
# 仍未配置时，JMS_LEGACY_PROVIDER=python 才会回退到 Python legacy 数据链路

# 可选：本地显式覆盖远端数据库配置
# DB_ENGINE=mysql
# DB_HOST=10.1.12.46
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=change_me
# DB_NAME=jumpserver

# 也支持 JMS_DB_* 命名方式
# JMS_DB_TYPE=mysql
# JMS_DB_HOST=10.1.12.46
# JMS_DB_PORT=3306
# JMS_DB_USERNAME=root
# JMS_DB_PASSWORD=change_me
# JMS_DB_NAME=jumpserver
